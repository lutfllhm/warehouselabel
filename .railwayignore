# Railway ignore file
# Files and directories to ignore during deployment

# Node modules (will be installed during build)
node_modules/
**/node_modules/

# Environment files (set in Railway dashboard)
.env
.env.local
.env.*.local

# Build artifacts
dist/
build/
**/dist/
**/build/

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Git
.git/
.gitignore

# Test files
**/*.test.js
**/*.spec.js
__tests__/
coverage/

# Documentation (optional, remove if you want to include)
*.md
!DEPLOYMENT.md

# Format files (not needed in production)
format/

# Scripts (not needed in production)
backend/scripts/
